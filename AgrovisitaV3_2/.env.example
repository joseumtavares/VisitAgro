# ============================================================
# VisitaPRO v3.2 — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite .env.local no Git.
# Na Vercel: Settings → Environment Variables
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
# URL do projeto (ex: https://abcxyz.supabase.co)
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# SERVICE ROLE KEY — poder total, NUNCA exposta ao browser
# Supabase → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...SERVICE_ROLE...

# ANON KEY — usada APENAS para verificação pública de RPC
# Supabase → Settings → API → anon (public)
# Ainda necessária para a RPC visitapro_verify_pass (SECURITY DEFINER)
SUPABASE_ANON_KEY=eyJhbGci...ANON...

# ── JWT ───────────────────────────────────────────────────────
# Segredo para assinar tokens JWT — mínimo 32 caracteres aleatórios
# Gere com: openssl rand -base64 32
JWT_SECRET=TROQUE_POR_STRING_ALEATORIA_SEGURA_32_CHARS_MINIMO

# ── APP ───────────────────────────────────────────────────────
# Ambiente de execução
NODE_ENV=production

# Duração da sessão JWT em segundos (padrão: 28800 = 8 horas)
JWT_EXPIRES_IN=28800
