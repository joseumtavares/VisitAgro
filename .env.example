# ─────────────────────────────────────────────────────────────
# Variáveis de ambiente — VisitaGroPro
# Copie para .env.local e preencha os valores reais.
# NUNCA comite o .env.local no git.
# ─────────────────────────────────────────────────────────────

# Supabase — obtenha em: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...sua-chave-anonima
SUPABASE_SERVICE_ROLE_KEY=eyJ...sua-chave-service-role  # NUNCA expor no browser

# JWT — OBRIGATÓRIO: mínimo 32 caracteres, gerado aleatoriamente
# Gere com: openssl rand -base64 48
# ATENÇÃO: sem esta variável a aplicação não sobe (exceção em runtime)
JWT_SECRET=substitua-por-uma-string-aleatoria-forte-minimo-32-chars

# Duração da sessão em segundos (padrão: 28800 = 8 horas)
JWT_EXPIRES_IN=28800
